{
  "name": "day-sources-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for international observance/name-day source lookups",
  "bin": {
    "day-sources": "./src/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "start": "node src/cli.js",
    "build:data": "node src/cli.js --date $(date +%F) --sources all --germany-mode --state BY --json > docs/data-latest.json"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
